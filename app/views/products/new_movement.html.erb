<h1> Create Movement for <%= @product.name %> </h1>

<div class="row">
    <div class="col-lg-12">
    <div class="card p-5">
    <table class="table">
        <tr>
            <th>Product ID</th>
            <td><%= @product.id %></td>
        </tr>
        <tr>
            <th>Product Name</th>
            <td><%= @product.name %></td>
        </tr>
        <tr>
            <th>Description</th>
            <td><%= @product.description %></td>
        </tr>
    </table>
    </div>
    </div>
</div>

<div class="row mt-4">
  <div class="col-lg-12">
    <div class="card p-4">
      <h2>Movements</h2>
      <%= form_with model: @movement, url: create_movement_product_path(@product) do |f| %>

        <% if @movement.errors.any? %>
          <div class="alert alert-danger">
            <h4>The following errors prevented the movement from being saved:</h4>
            <ul>
              <% @movement.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="form-group mb-3">
          <%= f.label :movement_type, "Movement Type" %>
          <%= f.select :movement_type, options_for_select(Movement.get_movement_types), {}, class: "form-control" %>
        </div>

        <div class="form-group mb-3">
          <%= f.label :quantity %>
          <%= f.number_field :quantity, class: "form-control" %>
        </div>

        <div class="form-group">
          <%= f.label :comment, "Comment" %>
          <%= f.text_area :comment, class:"form-control" %>
        </div>

        <div class="form-group mt-3">
          <%= f.submit "Create Movement", class: "btn btn-success" %>
          <%= link_to "Cancel", product_path(@product), class: "btn btn-danger ms-2" %>
        </div>

      <% end %> 
      </div>
  </div>
</div>
