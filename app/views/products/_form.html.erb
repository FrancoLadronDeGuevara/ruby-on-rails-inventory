<div class="row">
  <div class="col-lg-12">
  <div class="card p-5">
<%= form_with(model: product) do |form| %>
  <% if product.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(product.errors.count, "error") %> prohibited this product from being saved:</h2>

      <ul>
        <% product.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name, class:'form-control mb-2', placeholder:'Product name' %>
  </div>

  <div class="form-group">
    <%= form.label :reference, style: "display: block" %>
    <%= form.text_field :reference, class:'form-control mb-2' %>
  </div>

  <div class="form-group">
    <%= form.label :description, style: "display: block" %>
    <%= form.text_field :description, class:'form-control mb-2' %>
  </div>

  <div>
    <%= form.submit "Send", class:'btn btn-success mt-2' %>
  </div>
<% end %>


  </div>
  </div>
</div>

