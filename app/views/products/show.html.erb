<div class="row">
<div class="col-lg-12">
  <h1>Products Details</h1>
  <%= link_to "Back to Products", products_path, class: 'btn btn-warning' %>
  <div class="mt-3 d-flex gap-2">
  <%= link_to "Edit this product", edit_product_path(@product), class: 'btn btn-primary' %>
  <%= button_to "Delete this product", @product, method: :delete, data: { confirm: "Are you sure?" }, class: 'btn btn-danger' %>
  <div class="ms-auto">
    <%= link_to "Create Movement", new_movement_product_path(@product), class: 'btn btn-success' %>
    <%= link_to "Export to CSV", product_path(@product, format: :csv), class: 'btn btn-secondary ms-2' %>
  </div>
  </div>

  <div class="card mt-4">
    <table class="table">
      <tr>
        <th>ID</th>
        <td><%= @product.id %></td>
      </tr>
      <tr>
        <th>Name</th>
        <td><%= @product.name %></td>
      </tr>
      <tr>
        <th>Description</th>
        <td><%= @product.description %></td>
      </tr>
      <tr>
        <th>Stock</th>
        <td><%= @product.quantity %></td>
      <tr>
        <th>Created At</th>
        <td><%= @product.created_at.strftime("%B %d, %Y %H:%M") %></td>
      </tr>
      <tr>
        <th>Updated At</th>
        <td><%= @product.updated_at.strftime("%B %d, %Y %H:%M") %></td>
      </tr>
    </table>
  </div>
</div>
</div>


<div class="row mt-4">
  <div class="col-lg-12">
    <div class="card p-4">
      <h1>Movements</h1>
      <table class="table">
        <thead>
          <tr>
            <th>Type</th>
            <th>Quantity</th>
            <th>Comment</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% @product.movements.each do |movement| %>
            <tr>
              <td><%= movement.movement_type_name%></td>
              <td><%= movement.quantity %></td>
              <td><%= movement.comment %></td>
              <td><%= movement.created_at.strftime("%B %d, %Y %H:%M") %></td>
            </tr>
          <% end %>
      </table>
    </div>
  </div>
</div>